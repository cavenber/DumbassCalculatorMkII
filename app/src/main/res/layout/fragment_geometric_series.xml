<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/beige"
    android:layout_marginTop="?attr/actionBarSize"
    android:paddingTop="60dp"
    android:paddingHorizontal="10dp"
    android:layout_marginBottom="?attr/actionBarSize"
    tools:context=".GeometricSeries">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="10dp"
        android:gravity="center"
        android:textSize="28sp"
        android:textColor="@color/dark_brown"
        android:fontFamily="@font/milky_vintage"
        android:text="S(n) = T(1) * T(2) * T(3)... T(n)"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="28sp"
            android:textColor="@color/dark_brown"
            android:fontFamily="@font/milky_vintage"
            android:text="T(1) = " />

        <EditText
            android:id="@+id/gsr_t1"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:inputType="none"
            android:maxLines="1"
            android:textColor="@color/brown"
            android:textSize="28sp"
            android:fontFamily="@font/milky_vintage"
            android:backgroundTint="@color/dark_brown" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="28sp"
            android:textColor="@color/dark_brown"
            android:fontFamily="@font/milky_vintage"
            android:text="T(2) = " />

        <EditText
            android:id="@+id/gsr_t2"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:inputType="none"
            android:maxLines="1"
            android:textColor="@color/brown"
            android:textSize="28sp"
            android:fontFamily="@font/milky_vintage"
            android:backgroundTint="@color/dark_brown" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="28sp"
            android:textColor="@color/dark_brown"
            android:fontFamily="@font/milky_vintage"
            android:text="n = " />

        <EditText
            android:id="@+id/gsr_n"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:inputType="none"
            android:maxLines="1"
            android:textColor="@color/brown"
            android:textSize="28sp"
            android:fontFamily="@font/milky_vintage"
            android:backgroundTint="@color/dark_brown" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="28sp"
            android:textColor="@color/dark_brown"
            android:fontFamily="@font/milky_vintage"
            android:text="T(n) = " />

        <EditText
            android:id="@+id/gsr_tn"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:inputType="none"
            android:maxLines="1"
            android:textColor="@color/brown"
            android:textSize="28sp"
            android:fontFamily="@font/milky_vintage"
            android:backgroundTint="@color/dark_brown" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="28sp"
            android:textColor="@color/dark_brown"
            android:fontFamily="@font/milky_vintage"
            android:text="S(n) = " />

        <EditText
            android:id="@+id/gsr_sn"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:inputType="none"
            android:focusable="false"
            android:maxLines="1"
            android:textColor="@color/brown"
            android:textSize="28sp"
            android:fontFamily="@font/milky_vintage"
            android:backgroundTint="@color/dark_brown" />


    </LinearLayout>

    <include
        layout="@layout/input_base"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"/>

</LinearLayout>