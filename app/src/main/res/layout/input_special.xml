<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:columnCount="5"
    android:rowCount="3"
    android:padding="4dp"
    android:useDefaultMargins="true">

    <!-- Row 1 -->

    <Button
        android:id="@+id/btnSqrt"
        style="@style/Theme.DumbassCalculatorMk2.Button.smol"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:text="sqrt(" />

    <Button
        android:id="@+id/btnCbrt"
        style="@style/Theme.DumbassCalculatorMk2.Button.smol"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:text="cbrt(" />

    <Button
        android:id="@+id/btnNthrt"
        style="@style/Theme.DumbassCalculatorMk2.Button.smol"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:text="nthrt(" />

    <Button
        android:id="@+id/btnSin"
        style="@style/Theme.DumbassCalculatorMk2.Button.smol"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:text="sin(" />

    <Button
        android:id="@+id/btnAsin"
        style="@style/Theme.DumbassCalculatorMk2.Button.smol"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:text="asin(" />

    <!-- Row 2 -->

    <Button
        android:id="@+id/btnLn"
        style="@style/Theme.DumbassCalculatorMk2.Button.smol"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:text="ln(" />

    <Button
        android:id="@+id/btnLog10"
        style="@style/Theme.DumbassCalculatorMk2.Button.smol"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:text="log10(" />

    <Button
        android:id="@+id/btnLog2"
        style="@style/Theme.DumbassCalculatorMk2.Button.smol"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:text="log2(" />

    <Button
        android:id="@+id/btnCos"
        style="@style/Theme.DumbassCalculatorMk2.Button.smol"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:text="cos(" />

    <Button
        android:id="@+id/btnAcos"
        style="@style/Theme.DumbassCalculatorMk2.Button.smol"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:text="acos(" />

    <!-- Row 3 -->

    <Button
        android:id="@+id/btnPi"
        style="@style/Theme.DumbassCalculatorMk2.Button.smol"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:text="π"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btnE"
        style="@style/Theme.DumbassCalculatorMk2.Button.smol"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:text="e"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btnComma"
        style="@style/Theme.DumbassCalculatorMk2.Button.smol"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:text="," />

    <Button
        android:id="@+id/btnTan"
        style="@style/Theme.DumbassCalculatorMk2.Button.smol"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:text="tan(" />

    <Button
        android:id="@+id/btnAtan"
        style="@style/Theme.DumbassCalculatorMk2.Button.smol"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:text="atan(" />

</GridLayout>